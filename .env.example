# FashionOS — copy this file to .env and fill in real values
# NEVER commit .env to git

# ── Docker ───────────────────────────────────────────────
ODOO_IMAGE=odoo:19.0

# ── Database ─────────────────────────────────────────────
DB_USER=odoo
DB_PASSWORD=CHANGE_ME_strong_password
DB_NAME=fashionos

# ── Odoo admin ───────────────────────────────────────────
ODOO_ADMIN_PASSWORD=CHANGE_ME_admin_password

# ── Frontend ─────────────────────────────────────────────
# Dev: http://localhost:8069   |   Prod: https://api.yourdomain.com
NEXT_PUBLIC_ODOO_URL=http://localhost:8069

# ── JWT (set in Odoo Settings > FashionOS Config, not here) ──
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_at_least_32_chars

# ── VNPay ────────────────────────────────────────────────
VNPAY_TMN_CODE=YOUR_TMN_CODE
VNPAY_HASH_SECRET=YOUR_HASH_SECRET

# ── GHN Delivery ─────────────────────────────────────────
GHN_API_TOKEN=YOUR_GHN_TOKEN
GHN_SHOP_ID=0

# ── Zalo OA (optional) ───────────────────────────────────
ZALO_OA_TOKEN=YOUR_ZALO_TOKEN
ZALO_OA_SECRET=YOUR_ZALO_SECRET

# FashionOS — copy this file to .env and fill in real values
# NEVER commit .env to git

# ── Docker ───────────────────────────────────────────────
ODOO_IMAGE=odoo:19.0

# ── Database ─────────────────────────────────────────────
DB_USER=odoo
DB_PASSWORD=CHANGE_ME_strong_password
DB_NAME=fashionos

# ── Odoo admin ───────────────────────────────────────────
ODOO_ADMIN_PASSWORD=CHANGE_ME_admin_password

# ── Frontend ─────────────────────────────────────────────
# Dev: http://localhost:8069   |   Prod: https://api.yourdomain.com
NEXT_PUBLIC_ODOO_URL=http://localhost:8069
# Used for SEO metadataBase and canonical URLs
NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# ── JWT (set in Odoo Settings > FashionOS Config, not here) ──
# Generate: openssl rand -hex 32
JWT_SECRET_KEY=CHANGE_ME_at_least_32_chars

# ── VNPay ────────────────────────────────────────────────
VNPAY_TMN_CODE=YOUR_TMN_CODE
VNPAY_HASH_SECRET=YOUR_HASH_SECRET

# ── GHN Delivery ─────────────────────────────────────────
GHN_API_TOKEN=YOUR_GHN_TOKEN
GHN_SHOP_ID=0

# ── Zalo OA (optional) ───────────────────────────────────
ZALO_OA_TOKEN=YOUR_ZALO_TOKEN
ZALO_OA_SECRET=YOUR_ZALO_SECRET

# ── Sentry error monitoring (optional) ───────────────────
# Get DSN from sentry.io → Project → Settings → Client Keys
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=   # same value as SENTRY_DSN, exposed to browser
SENTRY_ENVIRONMENT=production
SENTRY_ORG=your-sentry-org
SENTRY_PROJECT=fashionos-frontend
SENTRY_AUTH_TOKEN=        # for source map upload in CI
SENTRY_TRACES_SAMPLE_RATE=0.05

# ── Backup (optional) ────────────────────────────────────
# rclone remote:bucket for off-site backup upload
# Leave empty to keep backups local only
# Example: RCLONE_REMOTE=r2:fashionos-backups
RCLONE_REMOTE=
BACKUP_KEEP_DAILY=7
BACKUP_KEEP_WEEKLY=4

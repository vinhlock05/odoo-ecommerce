<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!--
        Monthly cron: recompute lifetime spend and loyalty tiers for all
        active customers.  Runs on the 1st of each month at 02:00 UTC.
    -->
    <record id="cron_recalculate_loyalty_tiers" model="ir.cron">
        <field name="name">FashionOS: Recalculate Loyalty Tiers</field>
        <field name="model_id" ref="base.model_res_partner"/>
        <field name="state">code</field>
        <field name="code">
customers = env['res.partner'].search([
    ('customer_rank', '>', 0),
    ('active', '=', True),
])
customers.recompute_lifetime_spend()
        </field>
        <field name="interval_number">1</field>
        <field name="interval_type">months</field>
        <field name="active">True</field>
        <field name="user_id" ref="base.user_root"/>
    </record>
</odoo>

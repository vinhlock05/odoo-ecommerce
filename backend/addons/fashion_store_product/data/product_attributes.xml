<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        <!--
            S1 Master Data — Product Attributes
            noupdate="1": created once, not overwritten on upgrade.
            Admins can add more values via the Odoo UI freely.
        -->

        <!-- ================================================================
             Attribute: Kích thước (clothing sizes)
             ================================================================ -->
        <record id="attr_size" model="product.attribute">
            <field name="name">Kích thước</field>
            <field name="display_type">select</field>
            <field name="create_variant">always</field>
        </record>

        <record id="attr_size_xs" model="product.attribute.value">
            <field name="attribute_id" ref="attr_size"/>
            <field name="name">XS</field>
            <field name="sequence">1</field>
        </record>
        <record id="attr_size_s" model="product.attribute.value">
            <field name="attribute_id" ref="attr_size"/>
            <field name="name">S</field>
            <field name="sequence">2</field>
        </record>
        <record id="attr_size_m" model="product.attribute.value">
            <field name="attribute_id" ref="attr_size"/>
            <field name="name">M</field>
            <field name="sequence">3</field>
        </record>
        <record id="attr_size_l" model="product.attribute.value">
            <field name="attribute_id" ref="attr_size"/>
            <field name="name">L</field>
            <field name="sequence">4</field>
        </record>
        <record id="attr_size_xl" model="product.attribute.value">
            <field name="attribute_id" ref="attr_size"/>
            <field name="name">XL</field>
            <field name="sequence">5</field>
        </record>
        <record id="attr_size_2xl" model="product.attribute.value">
            <field name="attribute_id" ref="attr_size"/>
            <field name="name">2XL</field>
            <field name="sequence">6</field>
        </record>
        <record id="attr_size_3xl" model="product.attribute.value">
            <field name="attribute_id" ref="attr_size"/>
            <field name="name">3XL</field>
            <field name="sequence">7</field>
        </record>

        <!-- ================================================================
             Attribute: Size Quần (trouser waist sizes)
             ================================================================ -->
        <record id="attr_size_quan" model="product.attribute">
            <field name="name">Size Quần</field>
            <field name="display_type">select</field>
            <field name="create_variant">always</field>
        </record>

        <record id="attr_size_quan_28" model="product.attribute.value">
            <field name="attribute_id" ref="attr_size_quan"/>
            <field name="name">28</field>
            <field name="sequence">1</field>
        </record>
        <record id="attr_size_quan_29" model="product.attribute.value">
            <field name="attribute_id" ref="attr_size_quan"/>
            <field name="name">29</field>
            <field name="sequence">2</field>
        </record>
        <record id="attr_size_quan_30" model="product.attribute.value">
            <field name="attribute_id" ref="attr_size_quan"/>
            <field name="name">30</field>
            <field name="sequence">3</field>
        </record>
        <record id="attr_size_quan_31" model="product.attribute.value">
            <field name="attribute_id" ref="attr_size_quan"/>
            <field name="name">31</field>
            <field name="sequence">4</field>
        </record>
        <record id="attr_size_quan_32" model="product.attribute.value">
            <field name="attribute_id" ref="attr_size_quan"/>
            <field name="name">32</field>
            <field name="sequence">5</field>
        </record>
        <record id="attr_size_quan_33" model="product.attribute.value">
            <field name="attribute_id" ref="attr_size_quan"/>
            <field name="name">33</field>
            <field name="sequence">6</field>
        </record>
        <record id="attr_size_quan_34" model="product.attribute.value">
            <field name="attribute_id" ref="attr_size_quan"/>
            <field name="name">34</field>
            <field name="sequence">7</field>
        </record>

        <!-- ================================================================
             Attribute: Màu sắc (colours with hex codes)
             ================================================================ -->
        <record id="attr_color" model="product.attribute">
            <field name="name">Màu sắc</field>
            <field name="display_type">color</field>
            <field name="create_variant">always</field>
        </record>

        <record id="attr_color_black" model="product.attribute.value">
            <field name="attribute_id" ref="attr_color"/>
            <field name="name">Đen</field>
            <field name="html_color">#1A1A1A</field>
            <field name="sequence">1</field>
        </record>
        <record id="attr_color_white" model="product.attribute.value">
            <field name="attribute_id" ref="attr_color"/>
            <field name="name">Trắng</field>
            <field name="html_color">#F5F5F5</field>
            <field name="sequence">2</field>
        </record>
        <record id="attr_color_navy" model="product.attribute.value">
            <field name="attribute_id" ref="attr_color"/>
            <field name="name">Xanh navy</field>
            <field name="html_color">#1B2A4A</field>
            <field name="sequence">3</field>
        </record>
        <record id="attr_color_gray" model="product.attribute.value">
            <field name="attribute_id" ref="attr_color"/>
            <field name="name">Xám</field>
            <field name="html_color">#9E9E9E</field>
            <field name="sequence">4</field>
        </record>
        <record id="attr_color_olive" model="product.attribute.value">
            <field name="attribute_id" ref="attr_color"/>
            <field name="name">Xanh rêu</field>
            <field name="html_color">#6B6B3A</field>
            <field name="sequence">5</field>
        </record>
        <record id="attr_color_beige" model="product.attribute.value">
            <field name="attribute_id" ref="attr_color"/>
            <field name="name">Be</field>
            <field name="html_color">#D4B896</field>
            <field name="sequence">6</field>
        </record>
        <record id="attr_color_blue" model="product.attribute.value">
            <field name="attribute_id" ref="attr_color"/>
            <field name="name">Xanh dương</field>
            <field name="html_color">#2563EB</field>
            <field name="sequence">7</field>
        </record>
        <record id="attr_color_red" model="product.attribute.value">
            <field name="attribute_id" ref="attr_color"/>
            <field name="name">Đỏ</field>
            <field name="html_color">#DC2626</field>
            <field name="sequence">8</field>
        </record>
    </data>
</odoo>
